{
  "servers": {
    "xanadTools": {
      "type": "stdio",
      "command": "${workspaceFolder}/.github/hooks/scripts/xanad-workspace-mcp.py",
      "args": []
    },
    "git": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.github/hooks/scripts/git-mcp.py"
      ]
    },
    "web": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--with", "httpx",
        "--with", "markdownify",
        "--with", "beautifulsoup4",
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.github/hooks/scripts/web-mcp.py"
      ]
    },
    "time": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.github/hooks/scripts/time-mcp.py"
      ]
    },
    "security": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.github/hooks/scripts/security-mcp.py"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.github/hooks/scripts/github-mcp.py"
      ],
      "disabled": true
    },
    "sqlite": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.github/hooks/scripts/sqlite-mcp.py"
      ],
      "disabled": true
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/.github/hooks/scripts/mcp-sequential-thinking-server.py"
      ]
    }
  }
}