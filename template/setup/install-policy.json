{
  "schemaVersion": "0.1.0",
  "packageName": "xanadAssistant",
  "canonicalSurfaces": [
    "core-instructions",
    "instructions",
    "prompts",
    "agents",
    "skills",
    "lean-skills",
    "hook-scripts",
    "mcp-config"
  ],
  "sourceRoots": {
    "template": "template",
    "agents": "agents",
    "skills": "skills",
    "lean-pack": "packs/lean",
    "hooks": "hooks"
  },
  "surfaceSources": {
    "core-instructions": {
      "sourceRoot": "template",
      "path": "copilot-instructions.md",
      "kind": "file",
      "layer": "core"
    },
    "instructions": {
      "sourceRoot": "template",
      "path": "instructions",
      "kind": "directory",
      "layer": "core"
    },
    "prompts": {
      "sourceRoot": "template",
      "path": "prompts",
      "kind": "directory",
      "layer": "core"
    },
    "agents": {
      "sourceRoot": "agents",
      "path": ".",
      "kind": "directory",
      "layer": "pack"
    },
    "skills": {
      "sourceRoot": "skills",
      "path": ".",
      "kind": "directory",
      "layer": "pack"
    },
    "hook-scripts": {
      "sourceRoot": "hooks",
      "path": "scripts",
      "kind": "directory",
      "layer": "core"
    },
    "lean-skills": {
      "sourceRoot": "lean-pack",
      "path": "skills",
      "kind": "directory",
      "layer": "pack"
    },
    "mcp-config": {
      "sourceRoot": "template",
      "path": "vscode/mcp.json",
      "kind": "file",
      "layer": "core"
    }
  },
  "targetPathRules": {
    "core-instructions": {
      "targetRoot": ".github",
      "pathPattern": "copilot-instructions.md",
      "surface": "instructions"
    },
    "instructions": {
      "targetRoot": ".github/instructions",
      "surface": "instructions"
    },
    "prompts": {
      "targetRoot": ".github/prompts",
      "surface": "prompts"
    },
    "agents": {
      "targetRoot": ".github/agents",
      "surface": "agents"
    },
    "skills": {
      "targetRoot": ".github/skills",
      "surface": "skills"
    },
    "lean-skills": {
      "targetRoot": ".github/skills",
      "surface": "skills"
    },
    "hook-scripts": {
      "targetRoot": ".github/hooks/scripts",
      "surface": "hooks"
    },
    "mcp-config": {
      "targetRoot": ".vscode",
      "pathPattern": "mcp.json",
      "surface": "mcp"
    }
  },
  "ownershipDefaults": {
    "core-instructions": "local",
    "instructions": "local",
    "prompts": "local",
    "agents": "plugin-backed-copilot-format",
    "skills": "plugin-backed-copilot-format",
    "lean-skills": "plugin-backed-copilot-format",
    "hook-scripts": "local",
    "mcp-config": "local"
  },
  "strategyDefaults": {
    "core-instructions": "preserve-marked-markdown-blocks",
    "instructions": "token-replace",
    "prompts": "token-replace",
    "agents": "token-replace",
    "skills": "replace-verbatim",
    "lean-skills": "replace-verbatim",
    "hook-scripts": "replace-verbatim",
    "mcp-config": "merge-json-object"
  },
  "requiredConditions": {
    "lean-skills": [
      "packs.selected=lean"
    ],
    "hook-scripts": [
      "hooks.enabled"
    ],
    "mcp-config": [
      "mcp.enabled"
    ]
  },
  "tokenRules": [
    {
      "token": "{{WORKSPACE_NAME}}",
      "description": "Consumer workspace display name.",
      "required": false
    },
    {
      "token": "{{XANAD_PROFILE}}",
      "description": "Selected behavior profile.",
      "required": false
    },
    {
      "token": "{{PRIMARY_LANGUAGE}}",
      "description": "Primary programming language detected or configured for this workspace.",
      "required": false
    },
    {
      "token": "{{PACKAGE_MANAGER}}",
      "description": "Package manager detected or configured for this workspace.",
      "required": false
    },
    {
      "token": "{{TEST_COMMAND}}",
      "description": "Command used to run the test suite in this workspace.",
      "required": false
    },
    {
      "token": "{{RESPONSE_STYLE}}",
      "description": "Preferred response verbosity style.",
      "required": false
    },
    {
      "token": "{{AUTONOMY_LEVEL}}",
      "description": "How the assistant handles ambiguity.",
      "required": false
    },
    {
      "token": "{{AGENT_PERSONA}}",
      "description": "Tone and persona style for the assistant.",
      "required": false
    },
    {
      "token": "{{TESTING_PHILOSOPHY}}",
      "description": "Testing philosophy for this workspace.",
      "required": false
    },
    {
      "token": "{{pack:commit-style}}",
      "description": "Commit message style and conventions. Resolved from selected pack; defaults to Conventional Commits best practices.",
      "required": false
    },
    {
      "token": "{{pack:output-style}}",
      "description": "Agent response verbosity and formatting. Resolved from selected pack; defaults to thorough responses with context.",
      "required": false
    },
    {
      "token": "{{pack:plan-format}}",
      "description": "Plan output format and detail level. Resolved from selected pack; defaults to full phased plans with rationale.",
      "required": false
    },
    {
      "token": "{{pack:review-depth}}",
      "description": "Review severity reporting threshold. Resolved from selected pack; defaults to all severities including Advisory.",
      "required": false
    }
  ],
  "chmodRules": {
    "hook-scripts": "executable"
  },
  "retiredFilePolicy": {
    "defaultAction": "report-retired",
    "archiveRoot": ".xanadAssistant/archive",
    "entries": [
      {
        "id": "retired.agents.lifecycle-planning.agent.md",
        "target": ".github/agents/lifecycle-planning.agent.md",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/agents/xanadLifecycle.agent.md to match the canonical agent name."
      },
      {
        "id": "retired.agents.xanad-lifecycle-planning.agent.md",
        "target": ".github/agents/xanad-lifecycle-planning.agent.md",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/agents/xanadLifecycle.agent.md — 'planning' was a misnomer; this agent coordinates the full lifecycle."
      },
      {
        "id": "retired.agents.xanad-lifecycle.agent.md",
        "target": ".github/agents/xanad-lifecycle.agent.md",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/agents/xanadLifecycle.agent.md — standardized to camelCase naming."
      },
      {
        "id": "retired.skills.lifecycle-audit.SKILL.md",
        "target": ".github/skills/lifecycle-audit/SKILL.md",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/skills/lifecycleAudit/SKILL.md — standardized to camelCase naming."
      },
      {
        "id": "retired.hook-scripts.xanad-workspace-mcp.py",
        "target": ".github/hooks/scripts/xanad-workspace-mcp.py",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/hooks/scripts/xanadWorkspaceMcp.py — standardized to camelCase naming."
      },
      {
        "id": "retired.hook-scripts.git-mcp.py",
        "target": ".github/hooks/scripts/git-mcp.py",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/hooks/scripts/gitMcp.py — standardized to camelCase naming."
      },
      {
        "id": "retired.hook-scripts.github-mcp.py",
        "target": ".github/hooks/scripts/github-mcp.py",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/hooks/scripts/githubMcp.py — standardized to camelCase naming."
      },
      {
        "id": "retired.hook-scripts.mcp-sequential-thinking-server.py",
        "target": ".github/hooks/scripts/mcp-sequential-thinking-server.py",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/hooks/scripts/mcpSequentialThinkingServer.py — standardized to camelCase naming."
      },
      {
        "id": "retired.hook-scripts.security-mcp.py",
        "target": ".github/hooks/scripts/security-mcp.py",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/hooks/scripts/securityMcp.py — standardized to camelCase naming."
      },
      {
        "id": "retired.hook-scripts.sqlite-mcp.py",
        "target": ".github/hooks/scripts/sqlite-mcp.py",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/hooks/scripts/sqliteMcp.py — standardized to camelCase naming."
      },
      {
        "id": "retired.hook-scripts.time-mcp.py",
        "target": ".github/hooks/scripts/time-mcp.py",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/hooks/scripts/timeMcp.py — standardized to camelCase naming."
      },
      {
        "id": "retired.hook-scripts.web-mcp.py",
        "target": ".github/hooks/scripts/web-mcp.py",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/hooks/scripts/webMcp.py — standardized to camelCase naming."
      },
      {
        "id": "retired.skills.lean-output.SKILL.md",
        "target": ".github/skills/lean-output/SKILL.md",
        "defaultAction": "archive-retired",
        "retiredIn": "0.1.0",
        "notes": "Renamed to .github/skills/leanOutput/SKILL.md — standardized to camelCase naming."
      }
    ]
  },
  "packageFormatDeliveryRules": {
    "agents": {
      "defaultOwnership": "plugin-backed-copilot-format",
      "supportedOwnership": [
        "local",
        "plugin-backed-copilot-format"
      ],
      "notes": "Agents stay plugin-backed by default but can be localized for offline or workspace-specific installs."
    },
    "skills": {
      "defaultOwnership": "plugin-backed-copilot-format",
      "supportedOwnership": [
        "local",
        "plugin-backed-copilot-format"
      ],
      "notes": "Skills stay plugin-backed by default but can be localized when the workspace needs package-owned copies."
    },
    "lean-skills": {
      "defaultOwnership": "plugin-backed-copilot-format",
      "supportedOwnership": [
        "local",
        "plugin-backed-copilot-format"
      ],
      "notes": "Lean pack skills follow the same ownership model as core skills."
    }
  },
  "generationSettings": {
    "manifestSchemaVersion": "0.1.0",
    "manifestOutput": "template/setup/install-manifest.json",
    "includeRetiredFiles": true,
    "derivedArtifactStrategy": {
      "catalog": "generated-from-policy-and-registries",
      "mirrors": [],
      "indexes": []
    },
    "unmanagedSourceExcludes": [
      "template/setup/**",
      "packs/*/tokens.json"
    ]
  }
}