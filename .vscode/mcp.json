{
  "servers": {
    "xanadTools": {
      "type": "stdio",
      "command": "${workspaceFolder}/hooks/scripts/xanadWorkspaceMcp.py",
      "args": []
    },
    "git": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/hooks/scripts/gitMcp.py"
      ]
    },
    "web": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--with", "httpx",
        "--with", "markdownify",
        "--with", "beautifulsoup4",
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/hooks/scripts/webMcp.py"
      ]
    },
    "time": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/hooks/scripts/timeMcp.py"
      ]
    },
    "security": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/hooks/scripts/securityMcp.py"
      ]
    },
    "github": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv",
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/hooks/scripts/githubMcp.py"
      ],
      "disabled": true
    },
    "sqlite": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/hooks/scripts/sqliteMcp.py"
      ],
      "disabled": true
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/hooks/scripts/mcpSequentialThinkingServer.py"
      ]
    }
  }
}
