{
  "servers": {
    "xanadTools": {
      "type": "stdio",
      "command": "${workspaceFolder}/hooks/scripts/xanad-workspace-mcp.py",
      "args": []
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "uvx",
      "env": {
        "CLAUDE_TMPDIR": "${userHome}/.cache/uv",
        "TMPDIR": "${userHome}/.cache/uv"
      },
      "args": [
        "--from",
        "mcp[cli]",
        "mcp",
        "run",
        "${workspaceFolder}/hooks/scripts/mcp-sequential-thinking-server.py"
      ]
    }
  }
}
